	issn = {1476-4687},
	url = {https://www.nature.com/articles/nature08179},
	doi = {10.1038/nature08179},
	abstract = {The common assumption that lake ecosystem productivity is generally limited by nutrient availability is challenged by new findings from a study of twelve natural lakes in northern Sweden. In these lakes light supply is shown to be the limiting factor on biomass accumulation rather than nutrient supply. Many natural lakes, like these, are relatively small and nutrient-poor, so it seems likely that most lakes are limited by light and that nutrients control productivity mainly in lakes with atypically high input of nutrients.},
